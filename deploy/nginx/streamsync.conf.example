# Скопируй и подставь свой домен:
#   sudo cp deploy/nginx/streamsync.conf.example /etc/nginx/sites-available/streamsync
#   sudo ln -sf /etc/nginx/sites-available/streamsync /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# До certbot можно оставить только блок server на :80 для получения сертификата.

server {
    listen 80;
    listen [::]:80;
    server_name stream.example.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name stream.example.com;

    # Пути после certbot (обычно так):
    ssl_certificate     /etc/letsencrypt/live/stream.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/stream.example.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
