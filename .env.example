# === Обязательно для деплойера (тот, кто поднял бота с GitHub) ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# HTTPS через nginx + Let's Encrypt (без :8080). См. README → HTTPS
# PUBLIC_BASE_URL=https://stream.your-domain.com
# Локальный тест: http://localhost:8080
PUBLIC_BASE_URL=https://stream.your-domain.com

# Шифрование токенов в БД: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# === Сервер ===
HOST=0.0.0.0
PORT=8080
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# === Опционально ===
# RAWG_API_KEY=

# Ключи площадок (TWITCH_CLIENT_ID и т.д.) вводятся через бота при /setup.
# Ниже — только если хочешь задать глобальные ключи для всех пользователей:
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
